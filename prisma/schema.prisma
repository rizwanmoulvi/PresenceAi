// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id              String   @id @default(cuid())
  companyName     String
  industry        String
  geography       String
  products        String
  overallScore    Float    @default(0)
  modelScores     String   // JSON string
  insights        String   // JSON string
  recommendations String   // JSON string
  status          String   @default("pending") // pending | analyzing | complete | error
  unlocked        Boolean  @default(false)
  createdAt       DateTime @default(now())

  leads Lead[]
}

model Lead {
  id            String    @id @default(cuid())
  email         String
  analysisId    String
  company       String?
  industry      String?
  geography     String?
  products      String?
  score         Float?
  topRec        String?   // #1 recommendation title — personalisation anchor
  emailSubject  String?
  emailBodyText String?
  emailBodyHtml String?
  emailStatus   String    @default("pending") // pending | sent | bounced | replied | archived
  emailSentAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id])
}
